# ========================================
# Agente de Mercado - Variables de Entorno
# ========================================
# Copia este archivo a .env y completa los valores

# --- Agente ---
AGENT_MODE=SIMULATION          # SIMULATION | LIVE
INITIAL_CAPITAL_USD=300        # Capital inicial en USD
CYCLE_INTERVAL_MINUTES=10     # Intervalo del loop principal

# --- Base de Datos ---
DATABASE_URL=postgresql+asyncpg://agent:agent_secret_pw@localhost:5432/agente_mercado
REDIS_URL=redis://localhost:6379/0

# --- Crypto Exchanges ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true           # Usar testnet para desarrollo
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Datos Externos ---
COINGECKO_API_KEY=             # Demo key (opcional, mejora rate limits)
ETHERSCAN_API_KEY=             # Gratis en etherscan.io
GNEWS_API_KEY=                 # Gratis en gnews.io
NEWSAPI_KEY=                   # Gratis en newsapi.org
REDDIT_CLIENT_ID=              # Gratis en reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=

# --- LLM ---
GEMINI_API_KEY=                # Gratis en aistudio.google.com

# --- Notificaciones ---
TELEGRAM_BOT_TOKEN=            # Crear bot con @BotFather
TELEGRAM_CHAT_ID=              # Tu chat ID

# --- Seguridad API REST ---
JWT_SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars

# --- Docker PostgreSQL ---
POSTGRES_PASSWORD=agent_secret_pw
